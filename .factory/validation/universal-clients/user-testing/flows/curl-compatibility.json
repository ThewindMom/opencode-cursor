{
  "milestone": "universal-clients",
  "groupId": "curl-compatibility",
  "assertions": ["VAL-CLIENT-002"],
  "status": "pass",
  "summary": "All curl commands work correctly against proxy endpoints",
  "tests": [
    {
      "assertion": "VAL-CLIENT-002",
      "command": "curl http://localhost:32124/health",
      "expected": "HTTP 200 with JSON status",
      "actual": "HTTP 200, body: {\"status\":\"ok\",\"version\":\"2.3.20\",\"auth\":\"not_authenticated\",\"mcp\":{\"enabled\":true,\"servers\":0,\"tools\":0}}",
      "result": "pass"
    },
    {
      "assertion": "VAL-CLIENT-002",
      "command": "curl http://localhost:32124/v1/models",
      "expected": "HTTP 200 with JSON model list",
      "actual": "HTTP 200, body: {\"object\":\"list\",\"data\":[]} (empty list due to no auth, but proper format)",
      "result": "pass"
    },
    {
      "assertion": "VAL-CLIENT-002",
      "command": "curl -X POST http://localhost:32124/v1/chat/completions -d '{\"model\":\"auto\",\"messages\":[{\"role\":\"user\",\"content\":\"Hello\"}],\"stream\":true}'",
      "expected": "Proper error response (400 for unknown model without auth)",
      "actual": "HTTP 400, body: {\"error\":{\"message\":\"Unknown model: auto\",\"type\":\"invalid_request_error\",\"code\":\"model_not_found\",\"status\":400}}",
      "result": "pass"
    },
    {
      "assertion": "VAL-CLIENT-002",
      "command": "curl -X POST http://localhost:32124/v1/chat/completions -d 'not valid json'",
      "expected": "HTTP 400 with invalid_json error",
      "actual": "HTTP 400, body: {\"error\":{\"message\":\"Invalid JSON body\",\"type\":\"invalid_request_error\",\"code\":\"invalid_json\",\"status\":400}}",
      "result": "pass"
    },
    {
      "assertion": "VAL-CLIENT-002",
      "command": "curl -X POST http://localhost:32124/v1/chat/completions -d '{\"model\":\"test\"}'",
      "expected": "HTTP 400 with missing_messages error",
      "actual": "HTTP 400, body: {\"error\":{\"message\":\"messages is required\",\"type\":\"invalid_request_error\",\"code\":\"missing_messages\",\"status\":400}}",
      "result": "pass"
    }
  ],
